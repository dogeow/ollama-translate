{
  "manifest_version": 3,
  "name": "Ollama 翻译",
  "version": "0.0.1",
  "description": "Ollama 翻译扩展",
  "action": {
    "default_icon": {
      "16": "icons/icon-16.png",
      "32": "icons/icon-32.png"
    },
    "default_title": "Ollama 翻译设置",
    "default_popup": "popup.html"
  },
  "background": {
    "service_worker": "background.js"
  },
  "options_ui": {
    "page": "options.html"
  },
  "content_scripts": [
    {
      "matches": ["<all_urls>"],
      "js": ["content.js"],
      "run_at": "document_idle"
    }
  ],
  "permissions": ["storage", "contextMenus", "tabs", "scripting", "activeTab", "alarms"],
  "host_permissions": [
    "http://localhost:11434/*",
    "http://127.0.0.1:11434/*",
    "https://raw.githubusercontent.com/dogeow/ollama-translate/*"
  ],
  "commands": {
    "translate-selection": {
      "suggested_key": {
        "default": "Alt+T",
        "mac": "Alt+T"
      },
      "description": "翻译选中文本"
    }
  }
}
